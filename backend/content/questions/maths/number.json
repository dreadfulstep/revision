[
  {
    "id": "number-hcf",
    "topic": "number",
    "difficulty": 2,
    "type": "number",
    "image": null,
    "template": "Find the highest common factor (HCF) of {{a}} and {{b}}.",
    "variables": {
      "hcf": { "type": "pick", "options": [2, 3, 4, 5, 6] },
      "m1":  { "type": "int",  "min": 2, "max": 8 },
      "m2":  { "type": "int",  "min": 2, "max": 8 },
      "a":   { "type": "derived", "expr": "hcf * m1" },
      "b":   { "type": "derived", "expr": "hcf * m2" }
    },
    "answer": "hcf",
    "explanation": "Factors of {{a}}: multiples of {{hcf}} up to {{a}}. Factors of {{b}}: multiples of {{hcf}} up to {{b}}. HCF = {{answer}}"
  },
  {
    "id": "number-lcm",
    "topic": "number",
    "difficulty": 2,
    "type": "number",
    "image": null,
    "template": "Find the lowest common multiple (LCM) of {{a}} and {{b}}.",
    "variables": {
      "a": { "type": "pick", "options": [3, 4, 5, 6, 8] },
      "b": { "type": "pick", "options": [4, 5, 6, 7, 9] }
    },
    "answer": "Math.abs(a * b) / (function gcd(x,y){return y===0?x:gcd(y,x%y)})(a,b)",
    "explanation": "LCM({{a}}, {{b}}) = ({{a}} × {{b}}) ÷ HCF({{a}},{{b}}) = {{answer}}"
  },
  {
    "id": "number-percentage-of",
    "topic": "number",
    "difficulty": 1,
    "type": "number",
    "image": null,
    "template": "Find {{pct}}% of {{amount}}.",
    "variables": {
      "pct":    { "type": "pick", "options": [10, 15, 20, 25, 30, 40, 50, 75] },
      "amount": { "type": "int",  "min": 20, "max": 200, "multipleOf": 4 }
    },
    "answer": "(pct / 100) * amount",
    "tolerance": 0.01,
    "explanation": "{{pct}}% of {{amount}} = {{pct}} ÷ 100 × {{amount}} = {{answer}}"
  },
  {
    "id": "number-percentage-increase",
    "topic": "number",
    "difficulty": 2,
    "type": "number",
    "image": null,
    "template": "Increase {{amount}} by {{pct}}%.",
    "variables": {
      "pct":    { "type": "pick", "options": [5, 10, 15, 20, 25, 30] },
      "amount": { "type": "int",  "min": 20, "max": 200, "multipleOf": 4 }
    },
    "answer": "amount * (1 + pct/100)",
    "tolerance": 0.01,
    "explanation": "Multiply by (1 + {{pct}}/100) = {{1 + pct/100}}. Answer = {{amount}} × {{1 + pct/100}} = {{answer}}"
  },
  {
    "id": "number-percentage-decrease",
    "topic": "number",
    "difficulty": 2,
    "type": "number",
    "image": null,
    "template": "Decrease {{amount}} by {{pct}}%.",
    "variables": {
      "pct":    { "type": "pick", "options": [5, 10, 15, 20, 25, 30] },
      "amount": { "type": "int",  "min": 20, "max": 200, "multipleOf": 4 }
    },
    "answer": "amount * (1 - pct/100)",
    "tolerance": 0.01,
    "explanation": "Multiply by (1 − {{pct}}/100) = {{1 - pct/100}}. Answer = {{amount}} × {{1 - pct/100}} = {{answer}}"
  },
  {
    "id": "number-percentage-change",
    "topic": "number",
    "difficulty": 3,
    "type": "number",
    "image": null,
    "template": "A price changes from £{{original}} to £{{newval}}. What is the percentage change? Give your answer to 1 d.p.",
    "variables": {
      "original": { "type": "int", "min": 20, "max": 100 },
      "change":   { "type": "int", "min": 2,  "max": 20  },
      "sign":     { "type": "pick", "options": [1, -1] },
      "newval":   { "type": "derived", "expr": "original + sign * change" }
    },
    "answer": "((newval - original) / original) * 100",
    "tolerance": 0.1,
    "dp": 1,
    "unit": "%",
    "explanation": "% change = (new − original) ÷ original × 100 = ({{newval}} − {{original}}) ÷ {{original}} × 100 = {{answer}}%"
  },
  {
    "id": "ratio-simplify",
    "topic": "number",
    "difficulty": 2,
    "type": "text",
    "image": null,
    "template": "Simplify the ratio {{a*k}} : {{b*k}}",
    "variables": {
      "a": { "type": "int", "min": 2, "max": 8 },
      "b": { "type": "int", "min": 2, "max": 8, "notEqualTo": "a" },
      "k": { "type": "pick", "options": [2, 3, 4, 5] }
    },
    "textAnswer": "{{a}} : {{b}}",
    "acceptedAnswers": ["{{a}}:{{b}}"],
    "exactOnly": true,
    "explanation": "HCF of {{a*k}} and {{b*k}} is {{k}}. Divide both by {{k}}: {{a*k}}÷{{k}} : {{b*k}}÷{{k}} = {{a}} : {{b}}"
  },
  {
    "id": "ratio-share",
    "topic": "number",
    "difficulty": 3,
    "type": "number",
    "image": null,
    "template": "Share £{{total}} in the ratio {{p}} : {{q}}. How much is the larger share?",
    "variables": {
      "p":     { "type": "int", "min": 2, "max": 5 },
      "q":     { "type": "int", "min": 1, "max": 4 },
      "parts": { "type": "derived", "expr": "p + q" },
      "total": { "type": "derived", "expr": "parts * Math.floor(20 + Math.random() * 10)" }
    },
    "answer": "(total / (p + q)) * Math.max(p, q)",
    "tolerance": 0.01,
    "unit": "£",
    "explanation": "Total parts = {{p}} + {{q}} = {{parts}}. Value per part = £{{total}} ÷ {{parts}} = £{{total/parts}}. Larger share = {{Math.max(p,q)}} × £{{total/parts}} = £{{answer}}"
  },
  {
    "id": "number-standard-form-to-ordinary",
    "topic": "number",
    "difficulty": 3,
    "type": "number",
    "image": null,
    "template": "Write {{a}} × 10^{{n}} as an ordinary number.",
    "variables": {
      "a": { "type": "float", "min": 1.1, "max": 9.9, "dp": 1 },
      "n": { "type": "pick",  "options": [2, 3, 4] }
    },
    "answer": "a * Math.pow(10, n)",
    "explanation": "Move the decimal point {{n}} places to the right: {{a}} × 10^{{n}} = {{answer}}"
  },
  {
    "id": "number-standard-form-large",
    "topic": "number",
    "difficulty": 3,
    "type": "text",
    "image": null,
    "template": "Write {{val}} in standard form (e.g. 3.2 × 10^4).",
    "variables": {
      "a":   { "type": "float", "min": 1.1, "max": 9.9, "dp": 1 },
      "n":   { "type": "pick",  "options": [2, 3, 4] },
      "val": { "type": "derived", "expr": "a * Math.pow(10, n)" }
    },
    "textAnswer": "{{a}} × 10^{{n}}",
    "acceptedAnswers": ["{{a}}×10^{{n}}", "{{a}} x 10^{{n}}"],
    "exactOnly": true,
    "explanation": "{{val}} = {{a}} × 10^{{n}} in standard form"
  },
  {
    "id": "number-reverse-percentage",
    "topic": "number",
    "difficulty": 4,
    "type": "number",
    "image": null,
    "template": "After a {{pct}}% increase, a value is {{newval}}. What was the original value?",
    "variables": {
      "pct":     { "type": "pick", "options": [10, 20, 25, 50] },
      "original":{ "type": "int",  "min": 20, "max": 150, "multipleOf": 4 },
      "newval":  { "type": "derived", "expr": "original * (1 + pct/100)" }
    },
    "answer": "original",
