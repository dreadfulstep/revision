      "f2": { "type": "int", "min": 2, "max": 8 },
      "f3": { "type": "int", "min": 2, "max": 8 },
      "f4": { "type": "int", "min": 2, "max": 8 },
      "total": { "type": "derived", "expr": "f1 + f2 + f3 + f4" },
      "labels": { "type": "derived", "expr": "JSON.stringify(['Mon','Tue','Wed','Thu'])" },
      "values": { "type": "derived", "expr": "JSON.stringify([f1, f2, f3, f4])" },
      "hide_bar": { "type": "derived", "expr": "3" },
      "y_label": { "type": "derived", "expr": "'Frequency'" }
