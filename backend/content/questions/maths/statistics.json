    "answer": "f4",
    "explanation": "Missing value = total − other bars = {{total}} − {{f1}} − {{f2}} − {{f3}} = {{answer}}"
  },
  {
    "id": "stats-probability-basic",
    "topic": "statistics",
    "difficulty": 2,
    "type": "number",
    "image": null,
    "template": "A bag contains {{r}} red, {{b}} blue and {{g}} green counters. A counter is picked at random. What is the probability of picking a red counter? Give your answer as a decimal to 2 d.p.",
    "variables": {
      "r": { "type": "int", "min": 1, "max": 6 },
      "b": { "type": "int", "min": 1, "max": 6 },
      "g": { "type": "int", "min": 1, "max": 6 }
    },
    "answer": "r / (r + b + g)",
    "tolerance": 0.01,
    "dp": 2,
    "explanation": "P(red) = number of red ÷ total = {{r}} ÷ ({{r}} + {{b}} + {{g}}) = {{r}} ÷ {{r+b+g}} = {{answer}}"
  },
  {
    "id": "stats-probability-complement",
    "topic": "statistics",
    "difficulty": 2,
    "type": "number",
    "image": null,
    "template": "The probability of an event happening is {{p}}/{{q}}. What is the probability it does NOT happen? Give your answer as a fraction — enter the numerator only (denominator is {{q}}).",
    "variables": {
      "q": { "type": "pick", "options": [4, 5, 6, 8, 10] },
      "p": { "type": "int", "min": 1, "max": 4 }
    },
    "answer": "q - p",
    "explanation": "P(not happening) = 1 − {{p}}/{{q}} = ({{q}} − {{p}})/{{q}} = {{answer}}/{{q}}"
  },
