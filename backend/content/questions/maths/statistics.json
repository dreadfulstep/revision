      "values": { "type": "derived", "expr": "JSON.stringify([f1, f2, f3, f4])" },
      "y_label": { "type": "derived", "expr": "'Frequency'" }
    },
    "answer": "f1 + f2 + f3 + f4",
    "explanation": "Add all bar heights: {{f1}} + {{f2}} + {{f3}} + {{f4}} = {{answer}}"
  },
  {
    "id": "stats-bar-chart-missing",
    "topic": "statistics",
    "difficulty": 2,
    "type": "number",
    "image": { "type": "generated", "renderer": "bar-chart" },
    "template": "The total frequency is {{total}}. What is the missing bar value (shown as ?).",
    "variables": {
