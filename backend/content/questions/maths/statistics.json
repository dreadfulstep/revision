  {
    "id": "stats-mean-from-table",
    "topic": "statistics",
    "difficulty": 3,
    "type": "number",
    "image": null,
    "template": "A dataset has values 1, 2, 3, 4, 5 with frequencies {{f1}}, {{f2}}, {{f3}}, {{f4}}, {{f5}}. Find the mean.",
    "variables": {
      "f1": { "type": "int", "min": 1, "max": 6 },
      "f2": { "type": "int", "min": 1, "max": 6 },
      "f3": { "type": "int", "min": 1, "max": 6 },
      "f4": { "type": "int", "min": 1, "max": 6 },
      "f5": { "type": "int", "min": 1, "max": 6 }
    },
    "answer": "(1*f1 + 2*f2 + 3*f3 + 4*f4 + 5*f5) / (f1+f2+f3+f4+f5)",
    "tolerance": 0.01,
    "dp": 2,
    "explanation": "Mean = Σfx ÷ Σf = ({{1*f1+2*f2+3*f3+4*f4+5*f5}}) ÷ ({{f1+f2+f3+f4+f5}}) = {{answer}}"
  },
  {
    "id": "stats-bar-chart-read",
    "topic": "statistics",
    "difficulty": 1,
    "type": "number",
    "image": { "type": "generated", "renderer": "bar-chart" },
    "template": "What is the total frequency shown in the bar chart?",
