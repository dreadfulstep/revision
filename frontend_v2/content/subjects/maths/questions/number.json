  },
  {
    "id": "number-fraction-add-013",
    "topic": "number",
    "difficulty": 2,
    "image": null,
    "template": "Calculate {{p}}/{{q}} + {{r}}/{{s}}. Give your answer as a simplified fraction.",
    "variables": {
      "q": { "type": "pick", "options": [3, 4, 5, 6, 8] },
      "s": { "type": "pick", "options": [3, 4, 5, 6, 8] },
      "p": { "type": "int", "min": 1, "max": 4 },
      "r": { "type": "int", "min": 1, "max": 4 },
      "lcd": { "type": "derived", "expr": "lcm(q, s)" },
      "numSum": { "type": "derived", "expr": "p * (lcm(q,s)/q) + r * (lcm(q,s)/s)" },
      "g": { "type": "derived", "expr": "gcd(p * (lcm(q,s)/q) + r * (lcm(q,s)/s), lcm(q,s))" },
      "topAns": { "type": "derived", "expr": "(p * (lcm(q,s)/q) + r * (lcm(q,s)/s)) / gcd(p * (lcm(q,s)/q) + r * (lcm(q,s)/s), lcm(q,s))" },
      "botAns": { "type": "derived", "expr": "lcm(q,s) / gcd(p * (lcm(q,s)/q) + r * (lcm(q,s)/s), lcm(q,s))" }
    },
    "answerConfig": {
      "type": "text",
      "textAnswer": "{{topAns}}/{{botAns}}",
      "acceptedAnswers": ["{{topAns}}/{{botAns}}", "{{topAns}} / {{botAns}}"]
    },
    "explanation": "LCD of {{q}} and {{s}} = {{lcd}}. Convert: {{p}}/{{q}} = {{p*(lcd/q)}}/{{lcd}}, {{r}}/{{s}} = {{r*(lcd/s)}}/{{lcd}}. Sum = {{numSum}}/{{lcd}}. Simplify by dividing by {{g}}: {{topAns}}/{{botAns}}."
  },
  {
